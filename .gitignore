# ─────────────────────────────────────────────
#  MedEPCR Frontend — .gitignore
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Output ──────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Environment Variables ─────────────────────
# NEVER commit secrets to git
.env
.env.local
.env.*.local

# These are safe to commit (no secrets, only public URLs):
# .env.development  ← commit OK
# .env.production   ← commit OK (update URL before deploy)

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Vite Cache ────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# ── IDE & Editor ──────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── OS Files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ── TypeScript ────────────────────────────────
*.tsbuildinfo

# ── Misc ──────────────────────────────────────
.cache/
.eslintcache
*.pem
*.key
*.cert
